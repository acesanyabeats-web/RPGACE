{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/oracle", "dest": "/api/oracle.js" },
    { "src": "/api/composio", "dest": "/api/composio.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
